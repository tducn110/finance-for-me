# 🌍 APP CONFIGURATION
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# 💾 DATABASE (TiDB Serverless - HTTP Driver)
# Get these from TiDB Cloud Console
TIDB_HOST=
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=finance_tracker_v3

# 🔑 AUTHENTICATION (JWT)
JWT_SECRET=generate_a_secure_random_string_here
NEXT_PUBLIC_AUTH_COOKIE_NAME=finance_session

# 🎨 DESIGN TOKENS (Figma Integration)
FIGMA_PERSONAL_ACCESS_TOKEN=
FIGMA_FILE_KEY=

# 🤖 AI AGENT CONFIG (Local Only)
# These are used by your local Antigravity Agent
ECC_CORE_PATH=.agent
